rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == '7G4v3hEMtaVzI8MUDsXjVCNXGJz1';
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /publicReservations/{productId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['status', 'reservedAt', 'visitorUid'])
        && request.resource.data.status == 'reserved'
        && request.resource.data.visitorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /privateReservations/{productId} {
      allow create: if signedIn()
        && request.resource.data.visitorUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
